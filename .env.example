# ============================================================
# Configuration du site WordPress
# Copier ce fichier en .env et adapter les valeurs
#   cp .env.example .env
# ============================================================

# Nom unique du projet (utilise pour les noms de routeurs Traefik)
# Doit etre different pour chaque site lance simultanement
# Caracteres autorises : lettres, chiffres, tirets
PROJECT_NAME=monsite

# Domaine local du site (a ajouter dans le fichier hosts Windows)
# Exemple : 127.0.0.1 monsite.local pma.monsite.local mail.monsite.local
SITE_DOMAIN=monsite.local

# Nom du reseau Docker partage avec Traefik
# Doit correspondre a TRAEFIK_NETWORK dans local-network-multisite/.env (defaut : traefik-net)
TRAEFIK_NETWORK=traefik-net

# Base de donnees
DB_NAME=wordpress
DB_USER=wpuser
DB_PASSWORD=wppassword
DB_ROOT_PASSWORD=root

# Prefixe des tables WordPress
TABLE_PREFIX=wp_

# Mode debug WordPress (1 = active, 0 = desactive)
WP_DEBUG=1

# Limites memoire WordPress (constantes wp-config.php)
# Doit rester <= memory_limit defini dans docker/php/custom.ini
WP_MEMORY_LIMIT=256M
WP_MAX_MEMORY_LIMIT=256M

# Limites PHP — editer directement docker/php/custom.ini
# puis relancer : docker compose restart wordpress
# upload_max_filesize = 128M
# post_max_size       = 128M
# memory_limit        = 256M
# max_execution_time  = 300
